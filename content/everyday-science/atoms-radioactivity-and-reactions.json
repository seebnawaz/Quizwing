      "id": "atomsr-001",
      "q": "An atom consists of:",
      "options": [
        "Only protons and electrons",
        "Only neutrons and electrons",
        "Electrons, protons and neutrons",
        "Only nucleus"
      ],
      "correct": 2,
      "explanation": "Three subatomic particles: electron (−), proton (+), neutron (0).",
      "tags": []
    },
    {
      "id": "atomsr-002",
      "q": "The nucleus of an atom contains:",
      "options": [
