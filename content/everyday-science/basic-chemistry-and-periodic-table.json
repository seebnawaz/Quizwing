  "mcqs": [
    {
      "id": "basic--001",
      "q": "How many main types of chemical bonds are there?",
      "options": [
        "Two",
        "Three",
        "Four",
        "Five"
      ],
      "correct": 1,
      "explanation": "Three main types: covalent (equal sharing), polar covalent (unequal sharing) and ionic (electron transfer).",
      "tags": []
    },
    {
      "id": "basic--002",
      "q": "In an ionic bond, electrons are:",
      "options": [
        "Equally shared",
        "Unequally shared",
        "Transferred from one atom to another",
        "Not involved"
      ],
      "correct": 2,
      "explanation": "Ionic bonds form by transfer of electrons creating positive and negative ions.",
      "tags": []
    },
    {
      "id": "basic--003",
      "q": "H₂O contains which type of bond?",
      "options": [
        "Ionic",
        "Covalent (non-polar)",
        "Polar covalent",
        "Metallic"
      ],
      "correct": 2,
      "explanation": "Oxygen is more electronegative than hydrogen — unequal sharing creates a polar covalent bond.",
      "tags": []
    },
    {
      "id": "basic--004",
      "q": "NaCl is an example of:",
      "options": [
        "Covalent bond",
        "Polar covalent bond",
        "Ionic bond",
        "Hydrogen bond"
      ],
      "correct": 2,
      "explanation": "Sodium transfers an electron to chlorine — classic ionic bond between Na⁺ and Cl⁻.",
      "tags": []
    },
    {
      "id": "basic--005",
      "q": "In a covalent bond, electrons are:",
      "options": [
        "Lost",
        "Gained",
        "Shared",
        "Destroyed"
      ],
      "correct": 2,
      "explanation": "Atoms share pairs of electrons — equally in non-polar, unequally in polar covalent.",
      "tags": []
    },
    {
      "id": "basic--006",
      "q": "HCl molecule has which bond?",
      "options": [
        "Ionic",
        "Polar covalent",
        "Non-polar covalent",
        "Metallic"
      ],
      "correct": 1,
      "explanation": "Cl is more electronegative than H, so the shared pair is pulled towards Cl — polar covalent.",
      "tags": []
    },
    {
      "id": "basic--007",
      "q": "Which bond forms between two identical non-metal atoms?",
      "options": [
        "Ionic",
        "Polar covalent",
        "Non-polar covalent",
        "Hydrogen"
      ],
      "correct": 2,
      "explanation": "Equal electronegativity = equal sharing — non-polar covalent (e.g. H₂, O₂, N₂).",
      "tags": []
    },
    {
      "id": "basic--008",
      "q": "MgO is held together by which bond?",
      "options": [
        "Covalent",
        "Ionic",
        "Hydrogen",
        "Metallic"
      ],
      "correct": 1,
      "explanation": "Mg²⁺ and O²⁻ ions held by electrostatic attraction — ionic bond.",
      "tags": []
    },
    {
      "id": "basic--009",
      "q": "Which is the hardest natural substance?",
      "options": [
        "Graphite",
        "Charcoal",
        "Diamond",
        "Coal"
      ],
      "correct": 2,
      "explanation": "Diamond — a tetrahedral C-C covalent network, hardest known natural material.",
      "tags": []
    },
    {
      "id": "basic--010",
      "q": "Which allotrope of carbon conducts electricity?",
      "options": [
        "Diamond",
        "Graphite",
        "Coke",
        "Charcoal"
      ],
      "correct": 1,
      "explanation": "Graphite has free π (delocalised) electrons in its layered structure, allowing electrical conduction.",
      "tags": []
    },
    {
      "id": "basic--011",
      "q": "Coke is obtained from:",
      "options": [
        "Wood",
        "Coal",
        "Petroleum",
        "Bones"
      ],
      "correct": 1,
      "explanation": "Coke is produced by destructive distillation (heating without air) of coal.",
      "tags": []
    },
    {
      "id": "basic--012",
      "q": "Charcoal is mainly produced from:",
      "options": [
        "Coal",
        "Wood",
        "Limestone",
        "Sulphur"
      ],
      "correct": 1,
      "explanation": "Charcoal is made by heating wood in the absence of air (pyrolysis).",
      "tags": []
    },
